# Environment variables — keep your Beehiiv Publication ID off GitHub
.env

# Generated local config — created from .env by running: source .env && echo "window.BEEHIIV_PUB_ID='pub_$BEEHIVE_ID';" > config.js
config.js

# TIMPS font source files (large TTF binaries — keep the smaller WOFF2 copies)
TIMPS-Family-v2/*.ttf

# Python cache
__pycache__/
*.pyc

# Standalone scripts (not part of the site build)
send_to_beehiiv.py
convert_issues.py

# macOS
.DS_Store
